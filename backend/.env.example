# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/kisaan2consumer

# Server port
PORT=5000

# JWT secret - change this to a long random string
JWT_SECRET=change_this_to_a_long_random_secret_key

# Razorpay TEST mode keys (get free test keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Email verification (Gmail example — see README for setup steps).
# Leave as-is to skip real emails: verification codes will just be printed to
# the backend console instead, so registration/testing still works.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=xxxxxxxxxx@gmail.com
EMAIL_PASS=xxxxxxxxxxxxxxxx
EMAIL_FROM=FarmFresh <xxxxxxxxxx@gmail.com>

# Google Maps Geocoding API key — used to convert delivery addresses into GPS
# coordinates so the admin can assign the nearest delivery agent.
# Get one at https://console.cloud.google.com/google/maps-apis/credentials
# (requires enabling billing, but Google gives a free monthly credit that
# comfortably covers a student/demo project). Leave as-is to skip this feature —
# the app still works, admin just assigns agents manually instead of by distance.
GOOGLE_MAPS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
